<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CaseMgmt.Server</RootNamespace>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <!-- Reuse XRM framework via project references -->
  <ItemGroup>
    <ProjectReference Include="../../../xrm/src/Xrm.Core/Xrm.Core.csproj" />
    <ProjectReference Include="../../../xrm/src/Xrm.Blazor/Xrm.Blazor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
  </ItemGroup>

</Project>
