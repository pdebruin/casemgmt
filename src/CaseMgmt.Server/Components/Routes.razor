<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(Xrm.Blazor.Components.App).Assembly }"
        NotFoundPage="typeof(Xrm.Blazor.Components.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Xrm.Blazor.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
